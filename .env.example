# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/job_manage
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/job_manage
MONGODB_URI=mongodb+srv://admin:<mySecretPassword123>@cluster0.qwkl1qe.mongodb.net/?appName=Cluster0

# Server port (optional, defaults to 3000)
PORT=3000

# Node environment
NODE_ENV=development

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
